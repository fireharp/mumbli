      {
        "name": "Download",
        "url": "https://github.com/fireharp/mumbli/releases/latest"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Product",
        "pages": [
          "index",
          "voice-to-text-for-mac",
